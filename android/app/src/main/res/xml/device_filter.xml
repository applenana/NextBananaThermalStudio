<?xml version="1.0" encoding="utf-8"?>
<!-- USB OTG 设备过滤. 插入匹配 VID/PID (十进制) 的设备时系统会提示用户打开本应用.
     初始策略: 覆盖 Raspberry Pi (RP2040 默认 CDC), CH340/CH341, CP210x, FTDI, Prolific.
     如需扩展, 追加 <usb-device .../> 即可; 应用内部通过 usb_serial 二次过滤. -->
<resources>
    <!-- Raspberry Pi (RP2040, Pico, Pico W) VID=0x2E8A -->
    <usb-device vendor-id="11914"/>

    <!-- WCH CH340 / CH341  VID=0x1A86 -->
    <usb-device vendor-id="6790"/>

    <!-- Silicon Labs CP210x VID=0x10C4 -->
    <usb-device vendor-id="4292"/>

    <!-- FTDI VID=0x0403 -->
    <usb-device vendor-id="1027"/>

    <!-- Prolific PL2303 VID=0x067B -->
    <usb-device vendor-id="1659"/>
</resources>
